# ─── LEXONIMOUS Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in values before starting the server.

# Server
PORT=3000
NODE_ENV=development

# MongoDB — get this from mongodb.com/atlas (free)
# Format: mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/lexonimous
# Leave blank to run in memory-only mode (data lost on restart)
MONGODB_URI=

# Security
# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_STRING

# CORS — comma-separated list of allowed origins
# Use * only for development. Set your real domain in production.
ALLOWED_ORIGINS=http://localhost:3000

# Rate limits (requests per window)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
SOCKET_MSG_PER_MINUTE=30
SOCKET_JOIN_PER_MINUTE=10

# Room limits
MAX_ROOMS=2000
MAX_MSG_PER_ROOM=3000
MAX_ROOM_TITLE_LENGTH=60
MAX_MESSAGE_LENGTH=1000

# Message history sent on join
HISTORY_SIZE=50

EMPTY_ROOM_TTL_MS=600000